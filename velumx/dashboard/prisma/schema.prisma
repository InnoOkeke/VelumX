generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// VelumX Models
model ApiKey {
  id          String    @id @default(cuid())
  userId      String?   // Associated Supabase User ID
  name        String
  key         String    @unique
  status      String    @default("Active")
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now())
  usageLogs   UsageLog[]
  transactions Transaction[]

  @@index([userId])
  @@index([key])
}

model Transaction {
  id          String   @id @default(cuid())
  txid        String   @unique
  type        String
  userAddress String
  feeAmount   String
  status      String   @default("Pending")
  userId      String?  // Associated Supabase User ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
  apiKey      ApiKey?  @relation(fields: [apiKeyId], references: [id])
  apiKeyId    String?
}

model UsageLog {
  id           String   @id @default(cuid())
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([apiKeyId])
  @@index([createdAt])
}
